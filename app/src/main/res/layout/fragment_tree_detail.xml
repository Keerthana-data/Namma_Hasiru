<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nh_cream_soft"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_detail_species"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/nh_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="Neem" />

        <TextView
            android:id="@+id/text_detail_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/nh_text_secondary"
            tools:text="Planted on 12 May 2026 - Hesaraghatta" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Planting photo"
            android:textColor="@color/nh_text_primary"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/nh_divider"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/image_planting"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="@color/nh_surface"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Growth photo"
            android:textColor="@color/nh_text_primary"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/nh_divider"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/image_growth"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="@color/nh_surface"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_growth_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/growth_photo"
            app:backgroundTint="@color/nh_green_light"
            app:icon="@drawable/ic_camera_clean" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Survival status"
            android:textColor="@color/nh_text_primary"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sprouted"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sprouted" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_died"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Died" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_save_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_update"
            app:backgroundTint="@color/nh_green_primary" />
    </LinearLayout>
</ScrollView>
